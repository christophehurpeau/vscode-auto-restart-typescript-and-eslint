{
  "name": "vscode-auto-restart-typescript-and-eslint",
  "displayName": "Auto-Restarter: TypeScript & eslint Servers",
  "description": "Watches project configuration and automatically restarts TypeScript and ESLint language servers when relevant files change.",
  "publisher": "chrp",
  "version": "1.2.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "images/alt-icon.png",
  "homepage": "https://github.com/christophehurpeau/vscode-auto-restart-typescript-and-eslint.git",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/vscode-auto-restart-typescript-and-eslint.git"
  },
  "bugs": {
    "url": "https://github.com/christophehurpeau/vscode-auto-restart-typescript-and-eslint.git/issues"
  },
  "keywords": [
    "monitor",
    "file watch",
    "folder watch",
    "on change",
    "on delete",
    "on create",
    "auto",
    "restart",
    "tsconfig",
    "eslint",
    "eslintrc",
    "server",
    "turborepo",
    "lerna",
    "nx",
    "configuration",
    "reload",
    "typescript"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Auto Restart TypeScript / ESLint Servers",
      "properties": {
        "autoRestart.monitorFilesForTypescript": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Monitor TypeScript config files and restart its server."
        },
        "autoRestart.fileGlobForTypescript": {
          "type": "array",
          "default": [
            "**/package.json",
            "**/yarn.lock",
            "**/bun.lock",
            "**/package-lock.json",
            "**/tsconfig.{json,app.json,app.js,js,ts}"
          ],
          "scope": "window",
          "markdownDescription": "Monitors these files, supports [Glob Pattern](https://code.visualstudio.com/api/references/vscode-api#GlobPattern). Default [`**/tsconfig.{json,app.json,app.js,js,ts}`]."
        },
        "autoRestart.monitorFilesForESLint": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Monitor ESLint config files and restart its server."
        },
        "autoRestart.fileGlobForESLint": {
          "type": "array",
          "default": [
            "**/package.json",
            "**/yarn.lock",
            "**/bun.lock",
            "**/package-lock.json",
            "**/eslint.config.{js,cjs,mjs}"
          ],
          "scope": "window",
          "markdownDescription": "Monitors these files, supports [Glob Pattern](https://code.visualstudio.com/api/references/vscode-api#GlobPattern). Default [`**/.eslintrc.{js,cjs,mjs,yaml,yml,json}`, `**/eslint.config.{js,cjs,mjs}`]."
        },
        "autoRestart.showRestartNotificationForTypescript": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Show notification when restarts TypeScript server."
        },
        "autoRestart.showRestartNotificationForESLint": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Show notification when restarts ESLint server."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package --allow-star-activation",
    "install-vsix": "code --install-extension",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.3",
    "vsce": "2.15.0"
  }
}
